# Text-to-SQL Pipeline v0.1.0

# LLM Model - Ollama
TEXT2SQL_LLM_MODEL=qwen2.5-coder:1.5b
TEXT2SQL_USE_OLLAMA=true
TEXT2SQL_OLLAMA_BASE_URL=http://localhost:11434

# LLM Model - Transformers (fallback)
TEXT2SQL_USE_LOCAL_MODEL=false

# Generation
TEXT2SQL_N_SAMPLES=3
TEXT2SQL_TEMPERATURE=0.15
TEXT2SQL_MAX_TOKENS=256

# Retrieval
TEXT2SQL_TOP_K_TABLES=5
TEXT2SQL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
TEXT2SQL_USE_LOCAL_EMBEDDING=true

# Reranking - гибкая настройка модели
# Доступные модели:
#   - BAAI/bge-reranker-base (рекомендуемая, баланс скорость/качество)
#   - BAAI/bge-reranker-large (лучшее качество, медленнее)
#   - jinaai/jina-reranker-v1-base (лучше для русского языка)
#   - cross-encoder/ms-marco-MiniLM-L-6-v2 (быстрая, только английский)
TEXT2SQL_USE_RERANKING=true
TEXT2SQL_RERANKER_MODEL=jinaai/jina-reranker-v1-base
TEXT2SQL_USE_LOCAL_RERANKER=true
TEXT2SQL_RERANKER_TOP_K=5

# Retry & Confidence
TEXT2SQL_MAX_RETRIES=2
TEXT2SQL_CONFIDENCE_THRESHOLD=0.7
TEXT2SQL_EARLY_EXIT_THRESHOLD=0.75

# Multi-DB
TEXT2SQL_AUTO_DISCOVER_DBS=true
TEXT2SQL_TOP_K_DBS=3
TEXT2SQL_USE_LLM_RANKING=false

# Qdrant local
# TEXT2SQL_QDRANT_USE_LOCAL=true
# TEXT2SQL_QDRANT_LOCAL_PATH=qdrant_storage

# Qdrant - Use Docker container
TEXT2SQL_QDRANT_USE_LOCAL=false
TEXT2SQL_QDRANT_URL=http://localhost:6333
TEXT2SQL_QDRANT_API_KEY=

# Neo4j
TEXT2SQL_NEO4J_URI=bolt://localhost:7687
TEXT2SQL_NEO4J_USERNAME=neo4j
TEXT2SQL_NEO4J_PASSWORD=password

# Optimizations
TEXT2SQL_USE_4BIT_QUANTIZATION=true
TEXT2SQL_USE_TORCH_COMPILE=true
TEXT2SQL_USE_SEMANTIC_CACHE=true
TEXT2SQL_EARLY_EXIT_THRESHOLD=0.6
TEXT2SQL_MODEL_WARMUP=false

# Logging
TEXT2SQL_LOG_LEVEL=INFO

# ===========================================
# Additional Agent Settings (NEW)
# ===========================================

# Agent temperatures
TEXT2SQL_REFINER_TEMPERATURE=0.3
TEXT2SQL_JUDGE_TEMPERATURE=0.1
TEXT2SQL_VALIDATOR_TEMPERATURE=0.1

# Cache settings
TEXT2SQL_ROUTER_CACHE_MAX_SIZE=200
TEXT2SQL_RERANKER_CACHE_TTL=300
TEXT2SQL_CACHE_TTL_SECONDS=300

# SQL Guardrails
TEXT2SQL_SQL_DEFAULT_LIMIT=1000
TEXT2SQL_SQL_MAX_LIMIT=10000

# Retry settings
TEXT2SQL_LLM_RETRY_MAX_RETRIES=3
TEXT2SQL_LLM_RETRY_BASE_DELAY=0.5
TEXT2SQL_LLM_RETRY_MAX_DELAY=10.0

# Confidence cap
TEXT2SQL_MAX_CONFIDENCE_CAP=0.95

# ===========================================
# Router Ranking Settings (Hybrid)
# ===========================================

# Режим ранжирования: vector, llm, hybrid
# - vector: только vector score + graph связи (быстро, универсально)
# - llm: LLM ranking (медленно, точнее для сложных запросов)
# - hybrid: vector для простых, LLM для сложных (баланс)
TEXT2SQL_ROUTER_RANKING_MODE=llm

# Веса для vector ranking
TEXT2SQL_VECTOR_SCORE_WEIGHT=0.6
TEXT2SQL_GRAPH_SCORE_WEIGHT=0.2
TEXT2SQL_ROW_COUNT_WEIGHT=0.2

# Порог для hybrid режима
TEXT2SQL_HYBRID_LLM_THRESHOLD=0.5

# ===========================================
# Prompt Version Settings (NEW)
# ===========================================

# Prompt versions for each agent
# Available versions: v1, v2, v3 (check configs/prompts/*.yaml)
TEXT2SQL_ROUTER_PROMPT_VERSION=v2
TEXT2SQL_SQL_GENERATOR_PROMPT_VERSION=v2
TEXT2SQL_SQL_JUDGE_PROMPT_VERSION=v2
TEXT2SQL_SQL_REFINER_PROMPT_VERSION=v2

# Database description settings
TEXT2SQL_DB_DESCRIPTION_LANGUAGE=en
TEXT2SQL_DB_DESCRIPTION_VERSION=v1

# ===========================================
# Production Scaling Settings (1000+ DBs)
# ===========================================

# Query Result Caching
TEXT2SQL_USE_RESULT_CACHE=true
TEXT2SQL_RESULT_CACHE_MAX_SIZE=5000
TEXT2SQL_RESULT_CACHE_TTL_SECONDS=3600

# Connection Pooling
TEXT2SQL_USE_CONNECTION_POOL=true
TEXT2SQL_CONNECTION_POOL_SIZE=20
TEXT2SQL_CONNECTION_POOL_TIMEOUT=30

# Async Execution
TEXT2SQL_USE_ASYNC_EXECUTION=true
TEXT2SQL_MAX_WORKERS=8

# Vector Search Optimization
TEXT2SQL_VECTOR_SEARCH_BATCH_SIZE=50
TEXT2SQL_USE_APPROXIMATE_SEARCH=true
TEXT2SQL_HNSW_EF=128

