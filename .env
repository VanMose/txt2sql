# Text-to-SQL Pipeline v0.1.0

# LLM Model
TEXT2SQL_LLM_MODEL=Qwen2.5-Coder-1.5B
TEXT2SQL_USE_LOCAL_MODEL=true

# Generation
TEXT2SQL_N_SAMPLES=3
TEXT2SQL_TEMPERATURE=0.15
TEXT2SQL_MAX_TOKENS=256

# Retrieval
TEXT2SQL_TOP_K_TABLES=5
TEXT2SQL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
TEXT2SQL_USE_LOCAL_EMBEDDING=true

# Reranking - гибкая настройка модели
# Доступные модели:
#   - BAAI/bge-reranker-base (рекомендуемая, баланс скорость/качество)
#   - BAAI/bge-reranker-large (лучшее качество, медленнее)
#   - jinaai/jina-reranker-v1-base (лучше для русского языка)
#   - cross-encoder/ms-marco-MiniLM-L-6-v2 (быстрая, только английский)
TEXT2SQL_USE_RERANKING=true
TEXT2SQL_RERANKER_MODEL=jinaai/jina-reranker-v1-base
TEXT2SQL_USE_LOCAL_RERANKER=true
TEXT2SQL_RERANKER_TOP_K=5

# Retry & Confidence
TEXT2SQL_MAX_RETRIES=2
TEXT2SQL_CONFIDENCE_THRESHOLD=0.7
TEXT2SQL_EARLY_EXIT_THRESHOLD=0.75

# Multi-DB
TEXT2SQL_AUTO_DISCOVER_DBS=true
TEXT2SQL_TOP_K_DBS=2
TEXT2SQL_USE_LLM_RANKING=false

# Qdrant
TEXT2SQL_QDRANT_USE_LOCAL=true
TEXT2SQL_QDRANT_LOCAL_PATH=qdrant_storage

# Neo4j
TEXT2SQL_NEO4J_URI=bolt://localhost:7687
TEXT2SQL_NEO4J_USERNAME=neo4j
TEXT2SQL_NEO4J_PASSWORD=password

# Optimizations
TEXT2SQL_USE_4BIT_QUANTIZATION=true
TEXT2SQL_USE_TORCH_COMPILE=true
TEXT2SQL_USE_SEMANTIC_CACHE=true
TEXT2SQL_EARLY_EXIT_THRESHOLD=0.6
TEXT2SQL_MODEL_WARMUP=false

# Logging
TEXT2SQL_LOG_LEVEL=INFO
